{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CI",
    "NO_COLOR",
    "NEXT_TELEMETRY_DISABLED",
    "TURBO_TELEMETRY_DISABLED",
    "CONTROL_PLANE_PORT",
    "WEB_PORT",
    "PUBLIC_APP_URL",
    "CONTROL_PLANE_URL",
    "NEXT_PUBLIC_CONTROL_PLANE_URL",
    "POCKET_CTO_WEB_OPERATOR_NAME",
    "DATABASE_URL",
    "TEST_DATABASE_URL",
    "ARTIFACT_S3_ENDPOINT",
    "ARTIFACT_S3_REGION",
    "ARTIFACT_S3_BUCKET",
    "ARTIFACT_S3_ACCESS_KEY",
    "ARTIFACT_S3_SECRET_KEY",
    "ARTIFACT_S3_FORCE_PATH_STYLE",
    "CODEX_APP_SERVER_COMMAND",
    "CODEX_APP_SERVER_ARGS",
    "CODEX_DEFAULT_MODEL",
    "CODEX_DEFAULT_APPROVAL_POLICY",
    "CODEX_DEFAULT_SANDBOX",
    "CODEX_DEFAULT_SERVICE_NAME",
    "WORKSPACE_ROOT",
    "POCKET_CTO_SOURCE_REPO_ROOT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    }
  }
}
