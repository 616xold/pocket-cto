NODE_ENV=development

CONTROL_PLANE_PORT=4000
WEB_PORT=3000
PUBLIC_APP_URL=http://localhost:3000
CONTROL_PLANE_URL=http://localhost:4000
# Keep false for the default API-only mode. Set true to co-locate the worker for local approval and interrupt control.
CONTROL_PLANE_EMBEDDED_WORKER=false
NEXT_PUBLIC_CONTROL_PLANE_URL=http://localhost:4000
# Keep the env key stable during the pivot. The external product label is Pocket CFO.
POCKET_CTO_WEB_OPERATOR_NAME=Local Pocket CFO operator

# Keep current DB names for local continuity during F0/F1. Rename internals only in a later dedicated slice.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pocket_cto
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/pocket_cto_test
ARTIFACT_S3_ENDPOINT=http://localhost:9000
ARTIFACT_S3_REGION=us-east-1
ARTIFACT_S3_BUCKET=pocket-cto-artifacts
ARTIFACT_S3_ACCESS_KEY=minioadmin
ARTIFACT_S3_SECRET_KEY=minioadmin
ARTIFACT_S3_FORCE_PATH_STYLE=true

# Reserved Pocket CFO local roots for source-registry and wiki work.
SOURCE_REGISTRY_ROOT=
SOURCE_OBJECT_PREFIX=sources
CFO_WIKI_ROOT=
CFO_WIKI_EXPORT_ROOT=
POCKET_CFO_COMPANY_NAME=
POCKET_CFO_REPORTING_CURRENCY=USD

OPENAI_API_KEY=
OPENAI_MISSION_COMPILER_MODEL=gpt-5-mini
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5
EVALS_ENABLED=false
EVAL_BACKEND=openai_responses
EVAL_MODEL=gpt-5.4
EVAL_GRADER_MODEL=gpt-5.4-mini
# Used only when running the eval scripts with --with-reference.
EVAL_REFERENCE_MODEL=gpt-5.4
# Legacy eval env aliases remain accepted for backward compatibility, but the
# generic EVAL_* keys above now take precedence when both are set.
# OPENAI_EVALS_ENABLED=false
# OPENAI_EVAL_MODEL=gpt-5.4
# OPENAI_EVAL_GRADER_MODEL=gpt-5.4-mini
# OPENAI_EVAL_REFERENCE_MODEL=gpt-5.4

CODEX_APP_SERVER_COMMAND=codex
CODEX_APP_SERVER_ARGS=app-server
CODEX_DEFAULT_MODEL=gpt-5.2-codex
CODEX_DEFAULT_APPROVAL_POLICY=untrusted
CODEX_DEFAULT_SANDBOX=workspace-write
# Keep the env key and runtime seam stable; external naming is now Pocket CFO.
CODEX_DEFAULT_SERVICE_NAME=pocket-cfo-control-plane
# Leave blank to use a sibling <repo>.workspaces directory outside the source repo root.
WORKSPACE_ROOT=
POCKET_CTO_SOURCE_REPO_ROOT=
WORKER_RUN_ONCE=false
WORKER_POLL_INTERVAL_MS=30000

# Optional connector-only configuration. GitHub is no longer the primary product boundary.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
PWA_VAPID_PUBLIC_KEY=
PWA_VAPID_PRIVATE_KEY=
